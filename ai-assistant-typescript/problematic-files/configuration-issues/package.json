{
  "name": "ai-assistant-typescript",
  "version": "1.0.0",
  "description": "Production TypeScript implementation of AI Agentic Team system",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/server.ts",
    "dev:next": "next dev",
    "build": "tsc -b",
    "build:prod": "npm run clean && npm run build && npm run minify",
    "build:next": "next build",
    "clean": "rimraf dist coverage .next",
    "minify": "terser dist -o dist --compress --mangle",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:performance": "jest --testPathPattern=performance",
    "test:tool": "tsx test_tool_direct.ts",
    "test:orchestration": "tsx test_architectural_pattern_advisor.ts",
    "test:expert-registry": "tsx src/infrastructure/expert-registry/__tests__/runExpertRegistryTests.ts",
    "test:expert-registry:functional": "tsx src/infrastructure/expert-registry/__tests__/runExpertRegistryTests.ts --functional-only",
    "test:expert-registry:performance": "tsx src/infrastructure/expert-registry/__tests__/runExpertRegistryTests.ts --performance-only",
    "test:expert-registry:edge-cases": "tsx src/infrastructure/expert-registry/__tests__/runExpertRegistryTests.ts --edge-cases-only",
    "test:expert-registry:quick": "tsx src/infrastructure/expert-registry/__tests__/quickVectorDiscoveryTest.ts",
    "test:evaluation-driven-example": "tsx src/infrastructure/expert-registry/__tests__/runEvaluationDrivenExample.ts",
    "test:evaluation-driven-replanning": "tsx test-evaluation-driven-replanning.ts",
    "test:evaluation-integration-simple": "tsx test-evaluation-integration-simple.ts",
    "test:plan-replan-optimization": "tsx test-plan-replan-optimization.ts",
    "test:mo-rag-system": "tsx test-mo-rag-system.ts",
    "test:phase5-core": "tsx test-phase5-core.ts",
    "test:mo-rag-integration": "tsx test-mo-rag-integration.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint && npm run type-check && npm run test",
    "precommit": "lint-staged",
    "prepare": "husky install",
    "benchmark": "tsx scripts/benchmark.ts",
    "migrate": "tsx scripts/migrate/run-migration.ts",
    "docs": "typedoc --out docs/api src",
    "start": "node dist/index.js",
    "start:server": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "start:next": "next start",
    "deploy:staging": "npm run build:prod && tsx scripts/deploy/staging.ts",
    "deploy:prod": "npm run build:prod && tsx scripts/deploy/production.ts"
  },
  "dependencies": {
    "@langchain/community": "^0.3.48",
    "@langchain/langgraph": "^0.3.6",
    "@langchain/openai": "^0.5.16",
    "@mastra/core": "^0.10.8",
    "@mastra/memory": "^0.11.0",
    "@tanstack/react-query": "^5.0.0",
    "@trpc/client": "^11.4.3",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.4.3",
    "@types/js-yaml": "^4.0.9",
    "ai": "^4.3.16",
    "axios": "^1.8.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "ioredis": "^5.4.2",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.29",
    "n8n-core": "^1.14.1",
    "n8n-workflow": "^1.82.0",
    "next": "^15.0.0",
    "next-auth": "^4.24.0",
    "ollama": "^0.5.12",
    "ollama-ai-provider": "^0.15.2",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.53.2",
    "puppeteer": "^24.11.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "superjson": "^2.2.1",
    "systeminformation": "^5.22.0",
    "uuid": "^11.0.5",
    "winston": "^3.17.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.7.0",
    "@commitlint/config-conventional": "^19.7.0",
    "@playwright/test": "^1.53.2",
    "@swc/core": "^1.10.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.34",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-security": "^3.0.1",
    "fast-check": "^3.15.0",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "terser": "^5.37.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typedoc": "^0.27.6",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "keywords": [
    "ai",
    "assistant",
    "mastra",
    "typescript",
    "agents",
    "n8n",
    "automation"
  ],
  "author": "AI Assistant Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/ai-assistant-typescript.git"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/your-org/ai-assistant-typescript/issues"
  },
  "homepage": "https://github.com/your-org/ai-assistant-typescript#readme"
}
